DATABASE_URL="postgresql://code_review:code_review@localhost:5432/code_review_copilot?schema=public"

# Required app login account. The app creates one env-backed account and does not provide registration.
APP_AUTH_USERNAME="admin"
APP_AUTH_SECRET="change-me-login-secret"
APP_AUTH_SESSION_SECRET="change-me-session-signing-secret"
# Optional. When set, only these client IPs can access protected pages and APIs.
APP_AUTH_IP_WHITELIST=""

# Optional DingTalk notification fallback. UI settings take precedence.
DINGTALK_WEBHOOK_URL=""
DINGTALK_SECRET=""

# Required when starting docker-compose.monitoring.yml.
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="change-me-grafana-password"

# Pi 安装在 app 容器内，由 Bubblewrap 只读挂载到每个 review sandbox。
BUBBLEWRAP_BIN="bwrap"
BUBBLEWRAP_WORKSPACE_ROOT="/var/lib/code-review-copilot/runtime"
PI_HOST_PATH="/opt/pi"
PI_SANDBOX_MOUNT_PATH="/opt/pi"
PI_SANDBOX_TIMEOUT_SECONDS="7200"
