// 会话式代码审查 Agent —— 精简数据模型（4 表）
// 设计原则：review = session，线性 UIMessage 持久化，按仓库配模型/提示词。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// GitLab 接入凭证
model GitLabAccount {
  id            String       @id @default(cuid())
  url           String // GitLab 实例地址，如 https://gitlab.com
  accessToken   String // 个人访问令牌
  webhookSecret String? // Webhook 签名密钥（X-Gitlab-Token 比对）
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  repositories  Repository[]

  @@map("gitlab_accounts")
}

/// 仓库 + 按仓库的模型/提示词配置
model Repository {
  id              String        @id @default(cuid())
  gitLabAccountId String
  gitLabAccount   GitLabAccount @relation(fields: [gitLabAccountId], references: [id], onDelete: Cascade)
  gitLabProjectId Int
  name            String
  path            String // namespace/project
  description     String?
  watchBranches   String? // "main,develop,feature/*"，空=全部
  autoReview      Boolean       @default(true)
  // 模型配置（按仓库）
  modelProvider   String // openai | anthropic | openai-compatible
  modelId         String // 如 gpt-4o / claude-3-5-sonnet
  apiKey          String
  apiBaseUrl      String? // 自定义端点（openai-compatible 用）
  maxSteps        Int           @default(16) // agent loop 步数上限
  // 默认审查提示词（webhook 首轮），空则用内置
  defaultReviewPrompt String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sessions        Session[]

  @@unique([gitLabProjectId, gitLabAccountId])
  @@map("repositories")
}

/// 一次会话：审查会话（webhook 触发）或普通会话
model Session {
  id           String      @id @default(cuid())
  kind         String      @default("review") // review | chat
  title        String?
  repositoryId String?
  repository   Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  // 审查会话的 MR 元信息（普通会话为空）
  mrIid        Int?
  mrTitle      String?
  sourceBranch String?
  targetBranch String?
  commitSha    String?
  author       String?
  status       String      @default("running") // running | completed | failed
  error        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  messages     Message[]

  @@index([kind, updatedAt])
  @@index([repositoryId])
  @@map("sessions")
}

/// 线性 UIMessage 持久化
model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // user | assistant | system
  parts     Json // UIMessage.parts（text / tool-call / tool-result / reasoning）
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@map("messages")
}
