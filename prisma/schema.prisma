// 会话式代码审查 Agent
// 设计原则：review = session，线性 UIMessage 持久化，全局模型配置 + 仓库级覆盖。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// GitLab 接入凭证
model GitLabAccount {
  id            String       @id @default(cuid())
  url           String // GitLab 实例地址，如 https://gitlab.com
  accessToken   String // 个人访问令牌
  webhookSecret String? // Webhook 签名密钥（X-Gitlab-Token 比对）
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  repositories  Repository[]

  @@map("gitlab_accounts")
}

/// 全局 AI 模型配置
model AIModel {
  id          String       @id @default(cuid())
  provider    String // openai | anthropic | openai-compatible
  modelId     String // 如 gpt-4o / claude-3-5-sonnet
  apiKey      String
  apiBaseUrl  String?
  maxSteps    Int          @default(16)
  isDefault   Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  repositories Repository[]

  @@map("ai_models")
}

/// 仓库配置：多仓库列表 + 可选模型覆盖
model Repository {
  id              String        @id @default(cuid())
  gitLabAccountId String
  gitLabAccount   GitLabAccount @relation(fields: [gitLabAccountId], references: [id], onDelete: Cascade)
  gitLabProjectId Int
  name            String
  path            String // namespace/project
  description     String?
  watchBranches   String? // "main,develop,feature/*"，空=全部
  autoReview      Boolean       @default(true)
  defaultAIModelId String?
  defaultAIModel   AIModel?     @relation(fields: [defaultAIModelId], references: [id], onDelete: SetNull)
  // 仓库级自定义模型配置：全部为空时使用 defaultAIModel
  customProvider   String?
  customModelId    String?
  customApiKey     String?
  customApiBaseUrl String?
  customMaxSteps   Int?
  // 默认审查提示词（webhook 首轮），空则用内置
  defaultReviewPrompt String?
  // 输出渠道开关与钉钉配置
  enableMrComment Boolean       @default(false) // 是否回写代码平台评论（MR / Push）
  enableDingtalk  Boolean       @default(true) // 是否推送钉钉
  dingtalkWebhook String? // 钉钉机器人 webhook 地址
  dingtalkSecret  String? // 钉钉加签密钥
  // 项目记忆：跨次审查沉淀的约定/架构/历史问题（agent 读写）
  memory          String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sessions        Session[]

  @@unique([gitLabProjectId, gitLabAccountId])
  @@index([defaultAIModelId])
  @@map("repositories")
}

/// 一次会话：审查会话（webhook 触发）或普通会话
model Session {
  id           String      @id @default(cuid())
  kind         String      @default("review") // review | chat
  title        String?
  repositoryId String?
  repository   Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  // 审查会话的 MR 元信息（普通会话为空）
  mrIid        Int?
  mrTitle      String?
  sourceBranch String?
  targetBranch String?
  baseCommitSha String?
  commitSha    String?
  author       String?
  status       String      @default("running") // running | completed | failed
  error        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  messages     Message[]

  @@index([kind, updatedAt])
  @@index([repositoryId])
  @@map("sessions")
}

/// 线性 UIMessage 持久化
model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // user | assistant | system
  parts     Json // UIMessage.parts（text / tool-call / tool-result / reasoning）
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@map("messages")
}

/// 全局通知配置
model NotificationSetting {
  id                 String   @id @default(cuid())
  scope              String   @unique @default("global")
  dingtalkWebhookUrl String?
  dingtalkSecret     String?
  dingtalkEnabled    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("notification_settings")
}
