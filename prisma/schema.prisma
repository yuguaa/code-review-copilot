// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// GitLab 账号配置
model GitLabAccount {
  id                String        @id @default(cuid())
  url               String        // GitLab 实例 URL，如 https://gitlab.com
  accessToken       String        // 访问令牌
  webhookSecret     String?       // Webhook 密钥（可选）
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  repositories      Repository[]  // 关联的仓库

  @@map("gitlab_accounts")
}

// AI 模型配置
model AIModel {
  id                String        @id @default(cuid())
  provider          String        // 提供商: openai, claude, custom
  modelId           String        // 模型 ID，如 "gpt-4", "claude-3-5-sonnet"
  apiKey            String        // API 密钥
  apiEndpoint       String?       // 自定义 API 端点（仅用于自定义模型）
  maxTokens         Int?          // 最大 token 数（可选）
  temperature       Float?        // 温度参数（可选）
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  piProfiles        RepositoryPiProfile[]

  @@map("ai_models")
}

// 仓库配置
model Repository {
  id                String        @id @default(cuid())
  gitLabProjectId   Int           // GitLab 项目 ID
  name              String        // 仓库名称
  path              String        // 仓库路径，如 namespace/project-name
  description       String?       // 仓库描述（可选）
  gitLabAccountId   String
  gitLabAccount     GitLabAccount @relation(fields: [gitLabAccountId], references: [id], onDelete: Cascade)
  isActive          Boolean       @default(true)
  autoReview        Boolean       @default(false) // 是否自动审查
  watchBranches     String?       // 监听的分支（逗号分隔或通配符，如 "main,develop,feature/*"）
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  reviewLogs        ReviewLog[]   // 关联的审查日志
  piProfiles        RepositoryPiProfile[]
  memorySnapshots   RepositoryMemorySnapshot[]
  codeFileNodes     CodeFileNode[]
  codeRelationEdges CodeRelationEdge[]
  memoryFacts       RepositoryMemoryFact[]
  sandboxBinding    RepositorySandboxBinding?

  @@unique([gitLabProjectId, gitLabAccountId])
  @@map("repositories")
}

// 仓库与 OpenSandbox VM 的绑定；同一仓库复用同一个 sandbox。
model RepositorySandboxBinding {
  id                 String     @id @default(cuid())
  repositoryId       String     @unique
  repository         Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  sandboxId          String     @unique
  status             String     @default("running") // running, pausing, paused, error
  image              String
  piHostPath         String
  piSandboxMountPath String
  lastUsedAt         DateTime   @default(now())
  pausedAt           DateTime?
  error              String?
  metadataJson       Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  sessions           ReviewSandboxSession[]

  @@index([repositoryId, status])
  @@index([status, lastUsedAt])
  @@map("repository_sandbox_bindings")
}

// 单次 review 在仓库 sandbox 内的会话记录，绑定独立 worktree 和 Pi command。
model ReviewSandboxSession {
  id                         String                   @id @default(cuid())
  reviewLogId                String                   @unique
  reviewLog                  ReviewLog                @relation(fields: [reviewLogId], references: [id], onDelete: Cascade)
  repositorySandboxBindingId String
  repositorySandboxBinding   RepositorySandboxBinding @relation(fields: [repositorySandboxBindingId], references: [id], onDelete: Cascade)
  sandboxId                  String
  piCommandId                String?
  worktreePath               String
  status                     String                   @default("running") // running, cancelling, completed, failed, cancelled
  error                      String?
  startedAt                  DateTime                 @default(now())
  completedAt                DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  @@index([repositorySandboxBindingId, status])
  @@index([sandboxId, status])
  @@map("review_sandbox_sessions")
}

// 审查日志
model ReviewLog {
  id                String          @id @default(cuid())
  repositoryId      String
  repository        Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  mergeRequestId    Int             // GitLab MR ID
  mergeRequestIid   Int             // GitLab MR 内部 ID
  sourceBranch      String          // 源分支
  targetBranch      String          // 目标分支
  author            String          // 作者姓名
  authorUsername    String?         // 作者工号/用户名
  title             String          // MR 标题
  description       String?         // MR 描述（可选）
  commitSha         String          // 提交的 SHA
  commitShortId     String          // 提交的短 ID
  baseCommitSha     String?         // Push 事件的起始 SHA，用于覆盖一次 push 的多 commit diff
  pushCommitShasJson Json?          // Push 事件包含的 commit SHA 列表，用于新分支等无 before 场景
  status            String          // 状态: pending, completed, failed, cancelled
  error             String?         // 错误信息（如果有）
  totalFiles        Int             // 总文件数
  reviewedFiles     Int             @default(0) // 已审查文件数
  criticalIssues    Int             @default(0) // 严重问题数
  normalIssues      Int             @default(0) // 一般问题数
  suggestions       Int             @default(0) // 建议数
  changeSummary     String?         // 确定性变更摘要
  piRawOutputs      String?         // Pi 原始审查输出（JSON 格式，按文件存储）
  piPrompts         String?         // 发送给 Pi 的完整 Prompt（用于追溯）
  gitlabDiscussionId String?        // GitLab MR Discussion ID（用于更新占位评论）
  gitlabNoteId      Int?            // GitLab Note ID（用于更新占位评论）
  startedAt         DateTime        @default(now())
  completedAt       DateTime?       // 完成时间
  piRuns            PiReviewRun[]
  comments          ReviewComment[] // 关联的审查评论
  workflowNodes     ReviewWorkflowNode[]
  sandboxSession    ReviewSandboxSession?

  @@index([repositoryId, mergeRequestIid, commitSha])
  @@map("review_logs")
}

// 仓库 Pi 运行配置。
model RepositoryPiProfile {
  id                String        @id @default(cuid())
  repositoryId      String
  repository        Repository    @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  aiModelId         String
  aiModel           AIModel       @relation(fields: [aiModelId], references: [id], onDelete: Restrict)
  name              String
  description       String?
  prompt            String?
  promptMode        String        @default("extend")
  isActive          Boolean       @default(true)
  sortOrder         Int           @default(0)
  maxFindings       Int           @default(50)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  piRuns            PiReviewRun[]

  @@index([repositoryId, isActive, sortOrder])
  @@index([aiModelId])
  @@map("repository_pi_profiles")
}

// 单次审查中的 Pi 执行记录。
model PiReviewRun {
  id                String          @id @default(cuid())
  reviewLogId       String
  reviewLog         ReviewLog       @relation(fields: [reviewLogId], references: [id], onDelete: Cascade)
  piProfileId       String?
  piProfile         RepositoryPiProfile? @relation(fields: [piProfileId], references: [id], onDelete: SetNull)
  status            String
  error             String?
  summary           String?
  modelProvider     String
  modelId           String
  modelName         String
  promptSnapshot    String?
  promptMode        String
  startedAt         DateTime        @default(now())
  completedAt       DateTime?
  comments          ReviewComment[]
  workflowNodes     ReviewWorkflowNode[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([reviewLogId, piProfileId])
  @@index([reviewLogId, status])
  @@index([piProfileId])
  @@map("pi_review_runs")
}

// 审查评论
model ReviewComment {
  id                String        @id @default(cuid())
  reviewLogId       String
  reviewLog         ReviewLog     @relation(fields: [reviewLogId], references: [id], onDelete: Cascade)
  piReviewRunId     String?
  piReviewRun       PiReviewRun?  @relation(fields: [piReviewRunId], references: [id], onDelete: SetNull)
  filePath          String        // 文件路径
  lineNumber        Int           // 行号
  lineRangeEnd      Int?          // 行范围结束（可选，用于多行评论）
  severity          String        // 严重级别: critical, normal, suggestion
  content           String        // 评论内容
  sourceProfileName String?
  sourceProfileModel String?
  sourceProfilesJson Json?
  diffHunk          String?       // diff 片段（可选）
  confidence        Float?        // AI 置信度（0-1）
  gitlabCommentId   String?       // GitLab 评论 ID（已创建后）
  isPosted          Boolean       @default(false) // 是否已发布到 GitLab
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([reviewLogId, piReviewRunId, severity])
  @@index([piReviewRunId, isPosted])
  @@map("review_comments")
}

// 通知配置（全局）
model NotificationSetting {
  id                  String   @id @default(cuid())
  scope               String   @unique @default("global")
  dingtalkWebhookUrl  String?
  dingtalkSecret      String?
  dingtalkEnabled     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("notification_settings")
}

// 仓库 Code Graph 快照
model RepositoryMemorySnapshot {
  id                  String     @id @default(cuid())
  repositoryId        String
  repository          Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  branch              String
  commitSha           String
  status              String
  architectureSummary String
  memoryJson          Json?
  entrypointsJson     Json?
  layersJson          Json?
  conventionsJson     Json?
  risksJson           Json?
  confidence          Float      @default(0.7)
  lastIndexedAt       DateTime   @default(now())
  error               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([repositoryId, branch, commitSha])
  @@index([repositoryId, branch, status])
  @@map("repository_memory_snapshots")
}

// 代码文件节点
model CodeFileNode {
  id                String             @id @default(cuid())
  repositoryId      String
  repository        Repository         @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  branch            String
  commitSha         String
  filePath          String
  contentHash       String
  language          String
  role              String
  summary           String
  importsJson       Json?
  exportsJson       Json?
  lastIndexedAt     DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  symbols           CodeSymbolNode[]
  outgoingRelations CodeRelationEdge[] @relation("FromFile")
  incomingRelations CodeRelationEdge[] @relation("ToFile")

  @@unique([repositoryId, branch, commitSha, filePath])
  @@index([repositoryId, branch, commitSha])
  @@index([repositoryId, branch, role])
  @@map("code_file_nodes")
}

// 代码符号节点
model CodeSymbolNode {
  id                String             @id @default(cuid())
  fileNodeId        String
  fileNode          CodeFileNode       @relation(fields: [fileNodeId], references: [id], onDelete: Cascade)
  name              String
  kind              String
  signature         String?
  startLine         Int
  endLine           Int
  summary           String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  outgoingRelations CodeRelationEdge[] @relation("FromSymbol")
  incomingRelations CodeRelationEdge[] @relation("ToSymbol")

  @@index([fileNodeId, kind])
  @@index([name])
  @@map("code_symbol_nodes")
}

// 代码关系边
model CodeRelationEdge {
  id               String          @id @default(cuid())
  repositoryId     String
  repository       Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  branch           String
  fromFileNodeId   String
  fromFileNode     CodeFileNode    @relation("FromFile", fields: [fromFileNodeId], references: [id], onDelete: Cascade)
  fromSymbolNodeId String?
  fromSymbolNode   CodeSymbolNode? @relation("FromSymbol", fields: [fromSymbolNodeId], references: [id], onDelete: SetNull)
  toFileNodeId     String?
  toFileNode       CodeFileNode?   @relation("ToFile", fields: [toFileNodeId], references: [id], onDelete: SetNull)
  toSymbolNodeId   String?
  toSymbolNode     CodeSymbolNode? @relation("ToSymbol", fields: [toSymbolNodeId], references: [id], onDelete: SetNull)
  relationType     String
  confidence       Float           @default(0.7)
  evidence         String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([repositoryId, branch, fromFileNodeId])
  @@index([repositoryId, branch, toFileNodeId])
  @@index([repositoryId, branch, relationType])
  @@map("code_relation_edges")
}

// 可持续更新的仓库记忆事实
model RepositoryMemoryFact {
  id                 String     @id @default(cuid())
  repositoryId       String
  repository         Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  branch             String
  type               String
  content            String
  source             String
  confidence         Float
  evidence           String
  lastVerifiedCommit String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([repositoryId, branch, type, content])
  @@index([repositoryId, branch, type])
  @@map("repository_memory_facts")
}

// 动态审查过程图节点
model ReviewWorkflowNode {
  id              String        @id @default(cuid())
  reviewLogId     String
  reviewLog       ReviewLog     @relation(fields: [reviewLogId], references: [id], onDelete: Cascade)
  piReviewRunId   String?
  piReviewRun     PiReviewRun? @relation(fields: [piReviewRunId], references: [id], onDelete: Cascade)
  nodeKey         String
  parentNodeKey   String?
  kind            String
  status          String
  title           String
  summary         String?
  detail          String?
  sequence        Int
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  metricsJson     Json?
  rawJson         Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([reviewLogId, nodeKey])
  @@index([reviewLogId, sequence])
  @@index([reviewLogId, status])
  @@index([piReviewRunId])
  @@map("review_workflow_nodes")
}
